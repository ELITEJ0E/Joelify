{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile and app state",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "User ID" },
        "email": { "type": "string", "description": "User email" },
        "displayName": { "type": "string", "description": "User display name" },
        "photoURL": { "type": "string", "description": "User photo URL" },
        "appState": { "type": "string", "description": "JSON serialized AppState" },
        "createdAt": { "type": "number", "description": "Creation timestamp" },
        "updatedAt": { "type": "number", "description": "Last update timestamp" }
      },
      "required": ["uid", "appState", "createdAt", "updatedAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/UserProfile" },
      "description": "User profiles and their saved app state"
    }
  }
}
